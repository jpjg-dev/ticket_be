# Backend local environment example.

# Database
DB_URL=your-database-url
DB_USERNAME=your-database-username
DB_PASSWORD=your-database-password

# Application runtime
SPRING_PROFILES_ACTIVE=dev
PORT=8080

# Authentication and external PG
JWT_SECRET=your-jwt-secret-at-least-32-characters
TOSS_SECRET_KEY=your-toss-secret-key

# Cache Redis
CACHE_REDIS_HOST=your-cache-redis-host
CACHE_REDIS_PORT=6379
CACHE_REDIS_CONNECT_TIMEOUT=1s
CACHE_REDIS_TIMEOUT=2s

# Seat distributed lock
SEAT_LOCK_WAIT_TIME=0ms
SEAT_LOCK_WATCHDOG_TIMEOUT=30s
SEAT_LOCK_FALLBACK_MAX_CONCURRENT=2
SEAT_LOCK_FALLBACK_WAIT_TIME=100ms
SEAT_LOCK_RETRY_AFTER_SECONDS=1
